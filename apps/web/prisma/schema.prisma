generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?
  githubId      String?   @unique
  plan          Plan      @default(FREE)
  country       String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  purchases Purchase[]
  sessions  Session[]
  accounts  Account[]

  @@index([email])
}

model Agent {
  id          String    @id @default(cuid())
  slug        String    @unique
  name        String
  division    Division
  description String
  emoji       String
  tier        AgentTier
  fileSize    Int
  isFree      Boolean   @default(false)
  isPremium   Boolean   @default(false)
  priceUSD    Int?
  priceINR    Int?
  fileUrl     String?
  tags        String[]
  tools       String[]
  embedding   Float[]
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  bundleItems BundleItem[]
  purchases   Purchase[]

  @@index([division])
  @@index([tier])
  @@index([slug])
}

model Bundle {
  id               String   @id @default(cuid())
  slug             String   @unique
  name             String
  tagline          String
  description      String   @default("")
  emoji            String
  priceUSD         Int
  priceINR         Int
  originalPriceUSD Int
  isFeatured       Boolean  @default(false)
  targetAudience   String   @default("")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  items     BundleItem[]
  purchases Purchase[]
}

model BundleItem {
  id       String @id @default(cuid())
  bundleId String
  agentId  String
  bundle   Bundle @relation(fields: [bundleId], references: [id])
  agent    Agent  @relation(fields: [agentId], references: [id])

  @@unique([bundleId, agentId])
}

model Purchase {
  id              String          @id @default(cuid())
  userId          String
  agentId         String?
  bundleId        String?
  amount          Int
  currency        String
  paymentProvider PaymentProvider
  paymentId       String          @unique
  status          PurchaseStatus  @default(PENDING)
  createdAt       DateTime        @default(now())
  user   User    @relation(fields: [userId], references: [id])
  agent  Agent?  @relation(fields: [agentId], references: [id])
  bundle Bundle? @relation(fields: [bundleId], references: [id])

  @@index([userId])
  @@index([paymentId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

enum Plan {
  FREE
  PRO
  TEAM
  ENTERPRISE
}

enum Division {
  ENGINEERING
  DESIGN
  MARKETING
  SALES
  PRODUCT
  PROJECT_MANAGEMENT
  TESTING
  SUPPORT
  SPATIAL_COMPUTING
  SPECIALIZED
  GAME_DEVELOPMENT
  ACADEMIC
  PAID_MEDIA
}

enum AgentTier {
  S
  A
  B
  C
}

enum PaymentProvider {
  STRIPE
  RAZORPAY
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}
